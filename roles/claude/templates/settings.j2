{
{% if claude_code.api_key_helper %}
  "apiKeyHelper": "~/.claude/api-key-gen.sh",
{% endif %}
  "env": {
{% if lmstudio.host is defined or ollama.host is defined %}
    "API_TIMEOUT_MS": "3600000",
    "CLAUDE_STREAM_IDLE_TIMEOUT_MS": "600000",
{% endif %}
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
{% if claude_code.base_url != None %}
{% if claude_code.api_key_helper %}
    "CLAUDE_CODE_API_KEY_HELPER_TTL_MS": "21600000",
{% elif claude_code.auth_token != None %}
    "ANTHROPIC_AUTH_TOKEN": "{{ claude_code.auth_token }}",
    "ANTHROPIC_API_KEY": "",
{% endif %}
    "ANTHROPIC_BASE_URL": "{{ claude_code.base_url }}",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "{{ claude_code.model }}",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "{{ claude_code.model }}",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "{{ claude_code.model }}"
{% elif gcloud.core.project is defined %}
    "CLAUDE_CODE_USE_VERTEX": "1",
    "CLOUD_ML_REGION": "europe-west1",
    "ANTHROPIC_VERTEX_PROJECT_ID": "{{ gcloud.core.project }}",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-6",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5"
{% endif %}
  },
  "model": "{{ claude_code.model }}",
  "permissions": {
    "defaultMode": "acceptEdits",
    "additionalDirectories": [ "/tmp" ],
    "allow": [
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(tree:*)",
      "Bash(cargo --version:*)",
      "Bash(cargo tree:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(cargo doc:*)",
      "Bash(cargo test:*)",
      "Read(~/.zshrc)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.rs)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./private.eyaml)",
      "Bash(git push:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py",
    "padding": 0
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
